# Backend environment variables (Railway/Render/local)

# Railway usually provides PORT automatically, but keeping a default is fine.
PORT=5000

# MongoDB connection string (Atlas recommended for deployment)
# Example local:
# MONGO_URI=mongodb://localhost:27017/store-management
# Example Atlas:
# MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/store-management?retryWrites=true&w=majority
MONGO_URI=

# Allowed frontend origins for CORS (comma-separated)
# Example:
# CORS_ORIGIN=http://localhost:5173,https://your-site.netlify.app
CORS_ORIGIN=
